includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    paths:
        - src
    excludePaths:
        - src/Filament/*
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # larastan types hasOne relations as non-null; activeVersion is
        # genuinely nullable in the model's proxy accessors, so ?-> is correct.
        - identifier: nullsafe.neverNull
          path: src/Models/AiIntegration.php
        # currentAccessToken() is provided by Sanctum's HasApiTokens trait,
        # which larastan can't see on the framework's base User type.
        - identifier: method.notFound
          path: src/Http/Controllers/InvokeAiIntegrationController.php
        # larastan can't resolve the package's namespaced Blade view
        # (ai-gateway::docs) at analysis time; it exists at runtime.
        - message: '#expects view-string\|null, string given#'
          path: src/Http/Controllers/OpenApiController.php
